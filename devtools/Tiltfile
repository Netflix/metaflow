                        ],
                        'resources': {
                            'requests': {'cpu': '50m', 'memory': '256Mi'},
                            'limits':   {'cpu': '200m', 'memory': '512Mi'},
                        },
                    }],
                },
            },
        },
    }))
    k8s_yaml(encode_yaml({
        'apiVersion': 'v1',
        'kind': 'Service',
        'metadata': {'name': 'sfn-local'},
        'spec': {
            'selector': {'app': 'sfn-local'},
            'ports': [{'port': 8083, 'targetPort': 8083}],
        },
    }))
