# AIRFLOW
#################################################
if "airflow" in enabled_components:
    # PVC for DAG files (shared between scheduler and workers)
    k8s_yaml(encode_yaml({
        'apiVersion': 'v1',
        'kind': 'PersistentVolumeClaim',
        'metadata': {'name': 'airflow-dags'},
        'spec': {
            'accessModes': ['ReadWriteOnce'],
            'resources': {'requests': {'storage': '1Gi'}},
        },
    }))

    # Airflow requires a Fernet key for encrypting connection passwords.
    # We use a static dev key here (not secret).
    AIRFLOW_FERNET_KEY = "81HqDtbqAywKSOumSha3BhWNOdQ26slT6K0YaZeZyPs="

    helm_remote(
        'airflow',
        version=AIRFLOW_HELM_CHART_VERSION,
        repo_name='apache-airflow',
        repo_url='https://airflow.apache.org',
        set=[
            'airflowVersion=%s' % AIRFLOW_IMAGE_TAG,
            'defaultAirflowTag=%s' % AIRFLOW_IMAGE_TAG,
            # Use LocalExecutor (no Redis needed)
            'executor=LocalExecutor',
            # Disable PostgreSQL subchart — use a standalone one
            'postgresql.enabled=true',
            # Fernet key for encryption (dev only)
            'fernetKey=%s' % AIRFLOW_FERNET_KEY,
            # Disable flower (Celery UI, not needed for LocalExecutor)
            'flower.enabled=false',
            # Mount the DAGs PVC
            'dags.persistence.enabled=true',
            'dags.persistence.existingClaim=airflow-dags',
            'dags.gitSync.enabled=false',
            # Resource limits — keep the dev stack light
            'scheduler.resources.requests.memory=256Mi',
            'scheduler.resources.requests.cpu=100m',
            'scheduler.resources.limits.memory=512Mi',
            'scheduler.resources.limits.cpu=250m',
            'webserver.resources.requests.memory=256Mi',
            'webserver.resources.requests.cpu=100m',
            'webserver.resources.limits.memory=512Mi',
            'webserver.resources.limits.cpu=250m',
            # Default admin credentials (dev only)
            'webserver.defaultUser.enabled=true',
            'webserver.defaultUser.username=admin',
            'webserver.defaultUser.password=admin',
            'webserver.defaultUser.email=admin@example.com',
            'webserver.defaultUser.firstName=Admin',
            'webserver.defaultUser.lastName=User',
            'webserver.defaultUser.role=Admin',
        ],
    )

    k8s_resource(
        workload='airflow-webserver',
        # Forward host 8090 → container 8080 to avoid conflict with metadata-service (8080)
        port_forwards=['8090:8080'],
        links=[
            link('http://localhost:8090', 'Airflow UI'),
        ],
        labels=['airflow'],
        resource_deps=components['airflow'],
    )

    k8s_resource(
        workload='airflow-scheduler',
        labels=['airflow'],
        resource_deps=components['airflow'],
    )

    config_resources.append('airflow-webserver')
    config_resources.append('airflow-scheduler')

    metaflow_config["METAFLOW_AIRFLOW_REST_API_URL"] = "http://localhost:8090/api/v1"
    metaflow_config["METAFLOW_AIRFLOW_REST_API_USERNAME"] = "admin"
    metaflow_config["METAFLOW_AIRFLOW_REST_API_PASSWORD"] = "admin"
    metaflow_config["METAFLOW_AIRFLOW_KUBERNETES_DAGS_PATH"] = "/opt/airflow/dags"
    metaflow_config["METAFLOW_AIRFLOW_KUBERNETES_NAMESPACE"] = "default"

cmd = '''
ARCH=$(kubectl get nodes -o jsonpath='{.items[0].status.nodeInfo.architecture}')
case "$ARCH" in
  arm64)   echo linux-aarch64 ;;
  amd64)   echo linux-64 ;;
  *)       echo linux-64 ;;
esac
'''

# For @conda/@pypi emulation
metaflow_config["METAFLOW_KUBERNETES_CONDA_ARCH"] = str(local(cmd)).strip()

local_resource(
    name="generate-configs",
    cmd=write_config_files(),
    resource_deps=config_resources,
)

#################################################
# TEST IMAGES
#################################################
# Pre-baked test image with boto3/requests installed.
# Eliminates the ~2 min per-container pip install in kubernetes and batch steps.
# Used by ux_test_config.yaml for the argo-kubernetes and sfn-batch backends.
local_resource(
    name="build-test-image",
    # Build the image in the host Docker and load it into minikube's internal
    # image store so Kubernetes pods can pull it with imagePullPolicy=Never.
    cmd=(
        "docker build -t metaflow-test:python3.9 docker/metaflow-test/ && " +
        "minikube image load metaflow-test:python3.9"
    ),
    deps=["docker/metaflow-test/Dockerfile"],
    labels=["test"],
)
