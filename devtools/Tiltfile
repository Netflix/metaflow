            'uiBackend.resources.requests.cpu=100m',
            'uiBackend.resources.requests.memory=256Mi',
            'uiStatic.metaflowUIBackendURL=http://localhost:8083/api',
            'uiStatic.image.name=public.ecr.aws/outerbounds/metaflow_ui',
            'uiStatic.image.tag=v1.3.14',
            'uiStatic.resources.requests.cpu=25m',
            'uiStatic.resources.requests.memory=64Mi',
            'uiStatic.resources.limits.cpu=50m',
            'uiStatic.resources.limits.memory=128Mi',
        ]
    )

    k8s_resource(
        'metaflow-ui-static',
        port_forwards=['3000:3000'],
        links=[link('http://localhost:3000', 'Metaflow UI')],
        labels=['metaflow-ui'],
        resource_deps=components['ui']
    )

    k8s_resource(
        'metaflow-ui',
        port_forwards=['8083:8083'],
        links=[link('http://localhost:3000', 'Metaflow UI')],
        labels=['metaflow-ui'],
        resource_deps=components['ui']
    )

    metaflow_config["METAFLOW_UI_URL"] = "http://localhost:3000"

    config_resources.append('metaflow-ui')
    config_resources.append('metaflow-ui-static')

#################################################
# LOCALBATCH (local AWS Batch emulator)
#################################################
if "localbatch" in enabled_components:
    # Build the serve command. Inject MinIO credentials so that Docker
    # containers spawned by localbatch can reach S3 via host.docker.internal.
    localbatch_serve_cmd = (
        "localbatch --port 8000 --queue localbatch-default" +
        " --inject-env AWS_ACCESS_KEY_ID=rootuser" +
        " --inject-env AWS_SECRET_ACCESS_KEY=rootpass123" +
        " --inject-env AWS_ENDPOINT_URL_S3=http://host.docker.internal:9000" +
        # Metaflow reads METAFLOW_S3_ENDPOINT_URL to override the S3 endpoint
        # in containers (AWS_ENDPOINT_URL_S3 alone is not enough because
        # Metaflow explicitly calls os.getenv("METAFLOW_S3_ENDPOINT_URL")).
        " --inject-env METAFLOW_S3_ENDPOINT_URL=http://host.docker.internal:9000"
    )

    # Also forward the metadata service URL when it's part of this stack.
    if "metadata-service" in enabled_components:
        localbatch_serve_cmd += (
            " --inject-env METAFLOW_SERVICE_URL=http://host.docker.internal:8080" +
            " --inject-env METAFLOW_SERVICE_INTERNAL_URL=http://host.docker.internal:8080"
        )

    local_resource(
        name="localbatch",
        serve_cmd=localbatch_serve_cmd,
        readiness_probe=probe(
            http_get=http_get_action(port=8000, path="/health"),
            period_secs=2,
            initial_delay_secs=1,
        ),
        links=[
            link("http://localhost:8000/health", "localbatch health"),
            link("http://localhost:8000/docs",   "localbatch API docs"),
        ],
        labels=["localbatch"],
        resource_deps=components["localbatch"],
    )

    metaflow_config["METAFLOW_BATCH_JOB_QUEUE"] = "localbatch-default"
    metaflow_config["METAFLOW_BATCH_CLIENT_PARAMS"] = {"endpoint_url": "http://localhost:8000"}
    # Fake IAM role ARN required by the batch decorator (it is ignored by localbatch).
    metaflow_config["METAFLOW_ECS_S3_ACCESS_IAM_ROLE"] = "arn:aws:iam::123456789012:role/localbatch-task-role"

    config_resources.append("localbatch")

