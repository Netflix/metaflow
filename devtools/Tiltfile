        'kind': 'Job',
        'metadata': {'name': 'ddb-table-init'},
        'spec': {
            'ttlSecondsAfterFinished': 120,
            'template': {
                'spec': {
                    'restartPolicy': 'OnFailure',
                    'containers': [{
                        'name': 'init',
                        'image': 'amazon/aws-cli:latest',
                        'command': [
                            'aws', 'dynamodb', 'create-table',
                            '--endpoint-url', 'http://ddb-local:8000',
                            '--region', 'us-east-1',
                            '--table-name', 'metaflow-sfn',
                            '--attribute-definitions', 'AttributeName=pathspec,AttributeType=S',
                            '--key-schema', 'AttributeName=pathspec,KeyType=HASH',
                            '--billing-mode', 'PAY_PER_REQUEST',
                        ],
                        'env': [
                            {'name': 'AWS_DEFAULT_REGION',    'value': 'us-east-1'},
                            {'name': 'AWS_ACCESS_KEY_ID',     'value': 'test'},
                            {'name': 'AWS_SECRET_ACCESS_KEY', 'value': 'test'},
                        ],
                        'resources': {
                            'requests': {'cpu': '25m', 'memory': '64Mi'},
                            'limits':   {'cpu': '100m', 'memory': '128Mi'},
                        },
                    }],
                },
            },
        },
    }))
    k8s_resource('ddb-table-init', resource_deps=['ddb-local'], labels=['ddb-local'])

    metaflow_config["METAFLOW_SFN_DYNAMO_DB_CLIENT_PARAMS"] = {"endpoint_url": "http://localhost:8765"}
