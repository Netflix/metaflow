    # Fake EventBridge IAM role required by the step-functions deployer.
    # The devstack runs a minimal EventBridge stub (port 7777) so that
    # EventBridgeClient.schedule() succeeds without a real AWS account.
    metaflow_config["METAFLOW_EVENTS_SFN_ACCESS_IAM_ROLE"] = "arn:aws:iam::123456789012:role/sfn-events-role"
    config_resources.append('sfn-local')

    # Minimal EventBridge stub: accepts EventBridge API calls and returns
