                        # app-level args after the jar spec. Use --batch-endpoint and
                        # --dynamodb-endpoint CLI args because SFN Local uses the AWS SDK v1
                        # Java client, which doesn't read AWS_ENDPOINT_URL_* env vars.
                        'args': ['-jar', 'StepFunctionsLocal.jar',
